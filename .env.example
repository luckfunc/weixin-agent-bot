# ── Which backend (optional; helps when both API key and Codex are set) ──
# PROVIDER=openai
# PROVIDER=codex

# ── OpenAI API (sk-... from platform.openai.com) ──
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Used when OPENAI_MODEL is unset; if both are set, OPENAI_MODEL wins
# MODEL=gpt-4o

# ── ChatGPT / Codex (browser OAuth — no API key) ──
# CODEX_MODEL=gpt-5.2
# CODEX_AUTH_PATH=
# CODEX_TRANSPORT=auto
# NO_OPEN_BROWSER=1

# ── System prompt ──
# SYSTEM_PROMPT=You are a helpful assistant.

# ── Conversation (per WeChat user) ──
# CHAT_MAX_MESSAGES=50

# ── Saved CLI profile (API key / last choice) ──
# AUTH_STORE_PATH=

# ── WeChat ──
# WEIXIN_TOKEN_PATH=
