# LLM backend: openai | codex (auto-detected if omitted; interactive prompt when unset)
# LLM_MODE=openai

# Required for LLM_MODE=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Codex OAuth model
# CODEX_MODEL=gpt-5.2

# System prompt sent to the model
# SYSTEM_PROMPT=You are a helpful assistant.

# WeChat credential path (default: ~/.weixin-bot/credentials.json)
# WEIXIN_TOKEN_PATH=

# Codex auth storage path (default: ~/.weixin-gpt/codex-auth.json)
# CODEX_AUTH_PATH=

# Set to 1 to skip auto-opening the browser during OAuth
# NO_OPEN_BROWSER=1
