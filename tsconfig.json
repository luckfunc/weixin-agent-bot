{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "#types": ["./src/types/index.ts"],
      "#types/*": ["./src/types/*.ts"]
    },
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"]
}
